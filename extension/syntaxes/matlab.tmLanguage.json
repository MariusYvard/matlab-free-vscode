{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MATLAB",
  "scopeName": "source.matlab",
  "fileTypes": [
    "m"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#keywords-control"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#variable"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.percentage.matlab",
          "match": "%.*$"
        },
        {
          "name": "comment.block.matlab",
          "begin": "%\\{",
          "end": "%\\}"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.matlab",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.matlab",
              "match": "\"\""
            }
          ]
        },
        {
          "name": "string.quoted.single.matlab",
          "begin": "(?<=[=,\\(\\[\\{\\s;]|^)'",
          "end": "'(?!')",
          "patterns": [
            {
              "name": "constant.character.escape.matlab",
              "match": "''"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.matlab",
          "match": "\\b(function|classdef|properties|methods|events|enumeration|end|return|global|persistent)\\b"
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.matlab",
          "match": "\\b(if|elseif|else|for|parfor|while|do|switch|case|otherwise|try|catch|break|continue|return|spmd)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.matlab",
          "match": "\\b(true|false|pi|eps|inf|Inf|nan|NaN|i|j|end)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.matlab",
          "match": "(?<![\\w\\.])(\\d+\\.?\\d*|\\.\\d+)([eE][+-]?\\d+)?[ij]?(?![\\w\\.])"
        },
        {
          "name": "constant.numeric.hex.matlab",
          "match": "0[xX][0-9a-fA-F]+"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.matlab",
          "match": "\\+|-|\\*|\\.\\*|/|\\./|\\\\|\\.\\\\|\\^|\\.\\^"
        },
        {
          "name": "keyword.operator.comparison.matlab",
          "match": "==|~=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.matlab",
          "match": "&&|\\|\\||&|\\||~|!"
        },
        {
          "name": "keyword.operator.assignment.matlab",
          "match": "="
        },
        {
          "name": "keyword.operator.transpose.matlab",
          "match": "(?<=[\\w\\]\\)'\\d])('|\\.?')"
        },
        {
          "name": "keyword.operator.range.matlab",
          "match": ":"
        },
        {
          "name": "keyword.operator.other.matlab",
          "match": "@"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.matlab",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.matlab"
            }
          }
        }
      ]
    },
    "variable": {
      "patterns": [
        {
          "name": "variable.other.matlab",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}